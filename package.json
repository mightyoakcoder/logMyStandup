{
  "name": "log-my-standup",
  "type": "module",
  "scripts": {
    "build:frontend": "cd frontend && npm run build",
    "build": "npm run build:frontend && tsc",
    "dev": "concurrently \"cd frontend && npm start\" \"tsx watch --env-file=.env src/server.ts\""
  },
  "dependencies": {
    "@google-cloud/secret-manager": "^6.1.1",
    "@hono/node-server": "^1.19.9",
    "hono": "^4.11.7",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "@types/pg": "^8.16.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  }
}
